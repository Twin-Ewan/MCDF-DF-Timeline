{
    "compilerOptions": {
      "target": "ESNext",
      "module": "CommonJS",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./build",
      "rootDir": "./src",
      "resolveJsonModule": true,
      "sourceMap": true,
    },
    "include": ["src", "build/index.js"],
    "exclude": ["node_modules", "build"]
  }